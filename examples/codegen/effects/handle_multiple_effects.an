
effect Fail with
    fail: fn Unit -> a

effect Read a with
    read: fn Unit -> a

read_or_none f =
    handle Maybe.Some <| f ()
    | fail () -> Maybe.None
    | read () -> resume 5u32

foo () =
    if false then fail ()
    read ()

main () =
    print <| read_or_none foo

// args: --delete-binary --no-color
// expected stdout: Some 5
