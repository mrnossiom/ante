
effect Fail with
    fail: fn Unit -> a

effect Read a with
    read: fn Unit -> a

// read_or_zero (f: fn Unit -> a can Fail, Read U32) : Maybe a pure =
// TODO: This fails to type check without an annotation
read_or_zero f =
    handle Maybe.Some <| f ()
    | fail () -> Maybe.None
    | read () -> resume 5u32

foo () =
    if false then fail ()
    read ()

main () =
    print <| read_or_zero foo

// args: --delete-binary --no-color
