import Std.PVec
import Std.PVec.copy_pvec, print_pvec

main () =
    var vec = PVec.empty ()
    vec := vec.push 33
    vec := vec.push 44

    // Copy calls aren't inserted automatically yet...
    snapshot1 = (ref vec).*

    vec := vec.push 55
    println vec
    println snapshot1

    println (snapshot1.push 100)
    println vec
    0

// args: --delete-binary --no-color
// expected stdout:
// [33, 44, 55]
// [33, 44]
// [33, 44, 100]
// [33, 44, 55]

