import Std.Seq
import Std.Seq.clone_seq, print_seq

main () =
    var seq = Seq.empty ()
    seq := seq.push 33
    seq := seq.push 44

    // Copy calls aren't inserted automatically yet...
    snapshot1 = clone (ref seq)

    seq := seq.push 55
    println (clone (ref seq))
    println (clone (ref snapshot1))

    println (snapshot1.push 100)
    println seq

// args: --delete-binary --no-color
// expected stdout:
// [33, 44, 55]
// [33, 44]
// [33, 44, 100]
// [33, 44, 55]

