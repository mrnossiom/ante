import Std.Seq
import Std.Seq.copy_seq, print_seq

main () =
    var seq = Seq.empty ()
    seq := seq.push 33
    seq := seq.push 44

    // Copy calls aren't inserted automatically yet...
    snapshot1 = (ref seq).*

    seq := seq.push 55
    println seq
    println snapshot1

    println (snapshot1.push 100)
    println seq
    0

// args: --delete-binary --no-color
// expected stdout:
// [33, 44, 55]
// [33, 44]
// [33, 44, 100]
// [33, 44, 55]

