effect Count with
    count: fn Unit -> Unit

foo () =
    count ()
    repeat 10 fn _ -> count ()

handle_count f =
    handle
        f ()
        0
    | count () -> 1 + resume ()

main () =
    handle_count foo

// args: -e ast-t --no-color
// expected stdout:
// effect Count with
//     (count: fn Unit -> Unit can Count): fn Unit -> Unit
