//   |      ^^^
// 6 |     foo _a b = b
// 
// examples/typechecking/impl.an:8:6
//  8 | impl Foo F64 with	// error: Expected an identifier but found `Foo`
//    |      ^^^
//  9 |     foo _a b = b
// 
