
trait Foo a with
    foo: fn a a -> a

impl Foo I32 with
    foo _a b = b

impl Foo F64 with
    foo _a b = b


a = foo 1 2i32
b = foo 1.0 2.0
c = foo "one" "two"

// args: -e ast-t --no-color
// expected exit status: 1
// expected stdout:
// type Foo a [env] =
//     foo: fn a a [[env]] -> a
// 
// (a: _) = (foo: (error)) 1 2_I32
// 
// (b: _) = (foo: (error)) 1.0 2.0
// 
// (c: _) = (foo: (error)) "one" "two"

// expected stderr:
