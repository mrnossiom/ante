//     (foo: fn a [Bar a _] -> Unit pure) = fn (a: a) -> (bar: fn {Baz _ _} -> Bar _ (Baz _ _) can _) (a: a)
// 
// implicit (bar: fn {Baz a _} -> Bar a (Baz a _) can _) {(_: Baz a _)} : Bar a (Baz a) pure = Bar a (Baz a) with
//     (bar: fn a [Baz a _] -> Unit pure) = fn (a: a) -> (baz: Baz Thing Unit) (a: a)
// 
// implicit (baz: Baz Thing Unit) = Baz Thing with
//     (baz: fn Thing -> Unit pure) = fn (_: Thing) -> ()
// 
// implicit (does_not_match: fn {Print a _} -> Foo a (Print a _) can _) {(_: Print a _)} : Foo a (Print a) pure = Foo a (Print a) with
//     (foo: fn a [Print a _] -> Unit pure) = fn (_: a) -> ()
// 
// implicit (candidate2: Foo Thing Unit) = Foo Thing with
//     (foo: fn Thing -> Unit pure) = fn (_: Thing) -> ()

