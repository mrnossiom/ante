impl print_string: Print String with print s = _print_string s 0u32
impl print_ptr_char: Print (Ptr Char) with print s = print_c_string s

impl print_maybe {Print a}: Print (Maybe a) with
    print m =
        match m
        | Some a -> print a
        | None -> print "None"

impl print_ref {Print a} {Copy a}: Print (ref a) with
    print r = print r.*

// Naive replacement for printf which isn't supported by the cranelift backend
print_unsigned (x: U64): Unit =
    if x >= 10u64 then print_unsigned (x / 10u64)
    digit = x % 10u64 + cast c"0"
    putchar (cast digit)

print_signed (x: I64) (min: I64) (min_string: String): Unit =
    if x < 0i64 then
        if x == min then
            print min_string
        else
            putchar c"-"
            print_unsigned (unwrap (try_cast (0i64 - x)))
    else
        print_unsigned (unwrap (try_cast x))

_print_string (s: String) (i: U32): Unit =
    if i < s.length then
        off = offset_bytes (s.c_string) (cast i)
        c = deref_ptr off
        putchar c
        _print_string s (i + 1u32)

print_c_string (s: Ptr Char): Unit =
    c = deref_ptr s
    if c != c"\0" then
        putchar c
        print_c_string (offset_bytes s 1usz)

impl print_bool: Print Bool with
    print b =
        if b then print "true"
        else print "false"

