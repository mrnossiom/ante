trait Print t with
    print: fn t -> Unit

print = Print.print

println (x: t) {Print t} =
    Print.print x
    putchar c"\n"

impl print_u8:  Print U8  with print x = print_unsigned (cast x)
impl print_u16: Print U16 with print x = print_unsigned (cast x)
impl print_u32: Print U32 with print x = print_unsigned (cast x)
impl print_u64: Print U64 with print x = print_unsigned x
impl print_usz: Print Usz with print x = print_unsigned (cast x)

impl print_i8: Print I8 with
    print x = print_signed (cast x) -128i64 "-128"

impl print_i16: Print I16 with
    print x = print_signed (cast x) -32_768i64 "-32_768"

impl print_i32: Print I32 with
    print x = print_signed (cast x) -2_147_483_648i64 "-2_147_483_648"

impl print_i64: Print I64 with
    print x = print_signed x -9_223_372_036_854_775_808i64 "-9_223_372_036_854_775_808"

// TODO: This is broken for non-64-bit platforms.
impl print_isz: Print Isz with
    print x =
        print_signed (cast x) -9_223_372_036_854_775_808i64 "-9_223_372_036_854_775_808"


impl print_char: Print Char with print x = putchar x

// impl print_f64: Print F64 with print = print_float
// impl print_f32: Print F32 with print x = print_float (cast x)

