// impl add_float: Add (Float a) with (+) x y = intrinsic "AddFloat" x y
// impl add_char: Add Char with (+) (x: Char) (y: Char): Char = intrinsic "AddInt" x y

(+) = Add.(+)
(-) = Sub.(-)
(*) = Mul.(*)
(/) = Div.(/)
(%) = Mod.(%)

