trait Eq t with (==): fn t t -> Bool
impl eq_i8: Eq I8 with (==) x y = intrinsic "EqInt" x y
impl eq_i16: Eq I16 with (==) x y = intrinsic "EqInt" x y
impl eq_i32: Eq I32 with (==) x y = intrinsic "EqInt" x y
impl eq_i64: Eq I64 with (==) x y = intrinsic "EqInt" x y
impl eq_isz: Eq Isz with (==) x y = intrinsic "EqInt" x y
impl eq_u8: Eq U8 with (==) x y = intrinsic "EqInt" x y
impl eq_u16: Eq U16 with (==) x y = intrinsic "EqInt" x y
impl eq_u32: Eq U32 with (==) x y = intrinsic "EqInt" x y
impl eq_u64: Eq U64 with (==) x y = intrinsic "EqInt" x y
impl eq_usz: Eq Usz with (==) x y = intrinsic "EqInt" x y
// impl eq_int: Eq (Int a) with (==) x y = intrinsic "EqInt" x y
// impl eq_float: Eq (Float a) with (==) x y = intrinsic "EqFloat" x y
// 
impl eq_char: Eq Char with (==) (x: Char) (y: Char): Bool = intrinsic "EqInt" x y
impl eq_bool: Eq Bool with (==) (x: Bool) (y: Bool): Bool = intrinsic "EqInt" x y

(==) = Eq.(==)
(!=) (l: t) (r: t) {Eq t} = not (l == r)
(not) a = if a then false else true

trait Cmp a with
    (<): fn a a -> Bool

// TODO: Partial ordering screws everything up
(<) = Cmp.(<)
(>) (a: t) (b: t) {Cmp t} = b < a
(<=) (a: t) (b: t) {Cmp t} = not (b < a)
(>=) (a: t) (b: t) {Cmp t} = not (a < b)

impl cmp_i8: Cmp I8  with (<) x y = intrinsic "LessSigned" x y
impl cmp_i16: Cmp I16 with (<) x y = intrinsic "LessSigned" x y
impl cmp_i32: Cmp I32 with (<) x y = intrinsic "LessSigned" x y
impl cmp_i64: Cmp I64 with (<) x y = intrinsic "LessSigned" x y
impl cmp_isz: Cmp Isz with (<) x y = intrinsic "LessSigned" x y

impl cmp_u8: Cmp U8  with (<) x y = intrinsic "LessUnsigned" x y
impl cmp_u16: Cmp U16 with (<) x y = intrinsic "LessUnsigned" x y
impl cmp_u32: Cmp U32 with (<) x y = intrinsic "LessUnsigned" x y
impl cmp_u64: Cmp U64 with (<) x y = intrinsic "LessUnsigned" x y
impl cmp_usz: Cmp Usz with (<) x y = intrinsic "LessUnsigned" x y

// impl cmp_float: Cmp (Float a) with (<) x y = intrinsic "LessFloat" x y
// 
impl try_cast_i64_u64: TryCast I64 U64 with
    try_cast x =
        if x < 0i64 then None
        else Some (transmute x)

impl try_cast_u64: TryCast U64 I64 with
    try_cast x =
        if x > 9_223_372_036_854_775_807u64 then None
        else Some (transmute x)

trait Append a with
    (++): fn a a -> a

(++) = Append.(++)

// trait Extract collection index -> elem with
//     (.[): fn collection index -> elem
// 
// impl extract_ptr_usz: Extract (Ptr t) Usz t with
//     (.[) ptr index = deref_ptr <| offset ptr index
// 
// 
// // Bitwise functions
// // TODO: Move these to separate module
// //       Currently this is prevented by the use of 'intrinsic'
// //       which is limited to the prelude.
// 
// // Should these be traits instead?
// band (x: Int a) (y: Int a): Int a =
//     intrinsic "BitwiseAnd" x y
// 
// bor (x: Int a) (y: Int a): Int a =
//     intrinsic "BitwiseOr" x y
// 
// bxor (x: Int a) (y: Int a): Int a =
//     intrinsic "BitwiseXor" x y
// 
// bnot (x: Int a): Int a =
//     intrinsic "BitwiseNot" x
// 
// 
// type Type t = | MkType
// 
// size_of (v: Type t): Usz = intrinsic "SizeOf" v
// 
// offset (ptr: Ptr t) (index: Usz): Ptr t =
//     addr: Usz = transmute ptr
//     new_addr = addr + index * size_of (MkType: Type t)
//     transmute new_addr

offset_bytes (ptr: Ptr t) (index: Usz): Ptr t =
    addr: Usz = transmute ptr
    transmute (addr + index)

deref (x: ref t): t =
    intrinsic "Deref" x
// 
// // Temporary. We should instead be polymorphic over each reference type
// deref_mut (x: mut t): t =
//     intrinsic "Deref" x
// 
deref_ptr (p: Ptr t): t =
    deref (transmute p)
// 
// ptr_store (p: Ptr a) (value: a): Unit =
//     addr: mut a = transmute p
//     addr := value
// 
// array_insert (p: Ptr a) (index: Usz) (value: a): Unit =
//     offset p index |> ptr_store value
// 
// ptr_to_ref: fn (Ptr a) -> mut a = transmute
// 
(@) = deref

null (): Ptr a = transmute 0usz

transmute (x: a): b =
    intrinsic "Transmute" x

