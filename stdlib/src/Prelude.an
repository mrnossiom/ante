/*
        prelude.an
    Standard functions and datatypes pre-imported
    into every Ante source file.
*/

//C functions
extern
    // varargs is not supported by the cranelift backend
    // printf: Ptr Char - ... -> Unit
    puts: fn (Ptr Char) -> I32
    putchar: fn Char -> Unit
    getchar: fn Unit -> I32
    exit: fn I32 -> Unit
    malloc: fn Usz -> Ptr a
    calloc: fn /*items:*/Usz /*size:*/Usz -> Ptr a
    realloc: fn (Ptr a) Usz -> Ptr a
    free: fn (Ptr a) -> Unit
    memcpy: fn (Ptr a) (Ptr b) Usz -> Ptr a
    system: fn (Ptr Char) -> I32
    strlen: fn (Ptr Char) -> Usz

//C stdio
type File = f: Ptr Unit
type FilePos = f: Ptr Unit

type InFile = f: File
type OutFile = f: File

extern
    fopen: fn (Ptr Char) (Ptr Char) -> File
    fclose: fn File -> Unit

    fputs: fn (Ptr Char) OutFile -> I32
    fputc: fn I32 OutFile -> I32
    fwrite: fn (Ptr U8) Usz Usz OutFile -> Usz

    fgetc: fn InFile -> I32
    fgets: fn (Ptr Char) I32 InFile -> (Ptr Char)
    ungetc: fn I32 InFile -> I32

    fgetpos: fn File FilePos -> Unit
    ftell: fn File -> I32
    fsetpos: fn File FilePos -> Unit
    fseek: fn File I32 I32 -> I32

    feof: fn InFile -> I32
    ferror: fn File -> I32

type Maybe t =
   | None
   | Some t

unwrap (m: Maybe t): t =
    match m
    | Some x -> x
    | None -> panic "Tried to unwrap a None value"

type Result t e =
   | Ok t
   | Error e

// impl eq_maybe {Eq e}: Eq (Maybe e) with
//     (==) l r =
//         match l, r
//         | Some lv, Some rv -> lv == rv
//         | None, None -> true
//         | _ -> false
// 
// first (a, _) = a
// second (_, b) = b
// third (_, _, c) = c
// fourth (_, _, _, d) = d
// fifth (_, _, _, _, e) = e
// 
/// A type conversion from a to b
trait Cast a b with
    cast: fn a -> b

cast = Cast.cast

impl cast_same: Cast a a with
    cast a = a

impl cast_ptr_usz: Cast (Ptr a) Usz with
    cast ptr = transmute ptr

impl cast_usz_ptr: Cast Usz (Ptr a) with
    cast address = transmute address

