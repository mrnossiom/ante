impl sub_usz: Sub Usz with (-) x y = intrinsic "SubInt" x y
impl sub_f32: Sub F32 with (-) x y = intrinsic "SubFloat" x y
impl sub_f64: Sub F64 with (-) x y = intrinsic "SubFloat" x y

