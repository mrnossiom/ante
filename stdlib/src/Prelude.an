String.len (s: ref String): U32 =
    intrinsic "StringLen" s

String.data (s: ref String): Ptr Char =
    intrinsic "StringData" s

String.from_parts (buffer: Ptr Char) (len: U32): String =
    intrinsic "StringFromParts" buffer len

impl eq_string: Eq String with
    (==) l r =
        if l.len() != r.len() then
            false
        else
            memcmp (l.data ()) (r.data ()) (l.len ()) == 0

impl append_string: Append String with
    (++) s1 s2 =
        if s1.length == 0u32 then return s2
        if s2.length == 0u32 then return s1

        len = s1.length + s2.length
        buf = malloc (cast len + 1usz)

        memcpy buf (s1.c_string) (cast s1.length)

        buf_offset = cast (cast buf + s1.length)

        //copy terminating null too
        memcpy buf_offset (s2.c_string) (cast s2.length + 1usz)
        String.from_parts buf len

panic (msg: t) {Print t} =
    print msg
    exit 1
    // Unreachable, return any type
    deref_ptr (null ())

