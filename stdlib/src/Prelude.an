/// Represents a failable type cast from a to b
trait TryCast a b with
    try_cast: fn a -> Maybe b

try_cast = TryCast.try_cast

impl try_cast_from_cast {Cast a b}: TryCast a b with
    try_cast a = Some (cast a)


// // Huge block of intrinsic numeric operators incoming
trait Add n with (+): fn n n -> n
impl add_i8: Add I8 with (+) x y = intrinsic "AddInt" x y
impl add_i16: Add I16 with (+) x y = intrinsic "AddInt" x y
impl add_i32: Add I32 with (+) x y = intrinsic "AddInt" x y
impl add_i64: Add I64 with (+) x y = intrinsic "AddInt" x y
impl add_isz: Add Isz with (+) x y = intrinsic "AddInt" x y
impl add_u8: Add U8 with (+) x y = intrinsic "AddInt" x y
impl add_u16: Add U16 with (+) x y = intrinsic "AddInt" x y
impl add_u32: Add U32 with (+) x y = intrinsic "AddInt" x y
impl add_u64: Add U64 with (+) x y = intrinsic "AddInt" x y
impl add_usz: Add Usz with (+) x y = intrinsic "AddInt" x y
impl add_f32: Add F32 with (+) x y = intrinsic "AddFloat" x y
impl add_f64: Add F64 with (+) x y = intrinsic "AddFloat" x y

(+) = Add.(+)
(-) = Sub.(-)
(*) = Mul.(*)
(/) = Div.(/)
(%) = Mod.(%)

