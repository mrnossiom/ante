impl print_vec {p: Print t}: Print (ref Vec t) with
    print v =
        print "["
        print_helper v 0 {p}
        print "]"

print_helper (v: ref Vec q) (i: Usz) {Print q} : Unit =
    if i < v.len then
        // TODO: This fails to find the correct impl without
        // this type annotation
        print ((v.data.[i]) : q)
        if i + 1 != v.len then
            print ", "

        print_helper v (i + 1)

impl extract_vec: Extract (Vec t) Usz t with
    (.[) v i = v.data.[i]

